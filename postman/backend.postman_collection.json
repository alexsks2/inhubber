{
  "info": {
    "name": "Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "identity_url", "value": "http://localhost:8081" },
    { "key": "main_url",     "value": "http://localhost:8080" },
    { "key": "token",        "value": "" }
  ],
  "item": [
    {
      "name": "Identity Service",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@acme.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{identity_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@acme.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{identity_url}}/auth/validate"
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Create Company (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{main_url}}/companies",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"domain\": \"acme.com\"\n}"
            }
          }
        },
        {
          "name": "Get Company by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{main_url}}/companies/1"
          }
        }
      ]
    },
    {
      "name": "Persons",
      "item": [
        {
          "name": "Create Person (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{main_url}}/persons",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@acme.com\",\n  \"role\": \"USER\",\n  \"companyId\": 1\n}"
            }
          }
        },
        {
          "name": "List All Persons (Admin only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{main_url}}/persons"
          }
        },
        {
          "name": "Get Person by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{main_url}}/persons/1"
          }
        },
        {
          "name": "Update Name",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{main_url}}/persons/1/name",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"User Updated\"\n}"
            }
          }
        },
        {
          "name": "Update Email (Admin only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{main_url}}/persons/1/email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user.new@acme.com\"\n}"
            }
          }
        }
      ]
    }
  ]
}
